# 环境变量配置

# 项目配置
NEURALFIVE_ENV=development
NEURALFIVE_DEBUG=true
NEURALFIVE_LOG_LEVEL=INFO

# 游戏设置
DEFAULT_BOARD_SIZE=15
DEFAULT_AI_DIFFICULTY=medium
MAX_SEARCH_DEPTH=10
MAX_SEARCH_TIME=5000

# AI引擎配置
AI_ENGINE_TYPE=alphabeta
ENABLE_CACHE=true
CACHE_SIZE=1000000
ENABLE_JIT=true

# 机器学习配置
ML_MODEL_PATH=models/neuralfive_model.pkl
ML_TRAINING_DATA_PATH=data/training/
ML_ENABLE_TRAINING=false
ML_BATCH_SIZE=32
ML_LEARNING_RATE=0.001

# 性能优化
ENABLE_PARALLEL_SEARCH=true
MAX_WORKERS=4
ENABLE_GPU_ACCELERATION=false

# 日志配置
LOG_FILE=logs/neuralfive.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 数据库配置（如使用）
DATABASE_URL=sqlite:///neuralfive.db
DATABASE_ECHO=false

# 网络配置（如使用在线功能）
ENABLE_NETWORK=false
SERVER_HOST=localhost
SERVER_PORT=8080
API_KEY=your_api_key_here

# 测试配置
TEST_COVERAGE_MIN=90
TEST_TIMEOUT=30
PERFORMANCE_BENCHMARK=true